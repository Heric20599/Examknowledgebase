OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

PINECONE_API_KEY=
PINECONE_INDEX=schoolknowledgebase
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
EMBED_DIM=1536

CHUNK_SIZE=800
CHUNK_OVERLAP=120
MAX_PDF_MB=50

# In-process keep-alive loop. Leave KEEPALIVE_URL blank to disable.
# Set to your public app URL (e.g. https://your-app.onrender.com/health) so the
# loop generates outbound→inbound traffic against the platform load balancer.
KEEPALIVE_URL=
KEEPALIVE_INTERVAL_SECONDS=600
