OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

PINECONE_API_KEY=
PINECONE_INDEX=schoolknowledgebase
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
EMBED_DIM=1536

CHUNK_SIZE=800
CHUNK_OVERLAP=120
MAX_PDF_MB=50
MAX_ZIP_MB=200
INGEST_BATCH_SIZE=64

# In-process keep-alive (cron-style): pings every KEEPALIVE_INTERVAL_SECONDS (default 10 min).
# Set KEEPALIVE_URL to your public /health URL, or leave blank on Render to auto-use
# RENDER_EXTERNAL_URL/health when that env var is present.
KEEPALIVE_URL=https://schoolexam-725m.onrender.com/health
KEEPALIVE_INTERVAL_SECONDS=600
